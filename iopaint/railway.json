{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "iopaint start --model=$IOPAINT_MODEL --model-dir=$IOPAINT_MODEL_DIR --device=$IOPAINT_DEVICE --host=$IOPAINT_HOST --port=$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  }
}
